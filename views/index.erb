<% if logged_in? %>
  <h2>You are logged in. Welcome <%= current_user['name'] %></h2>
    <form action="/sessions" method="POST">
      <input type="hidden" name="_method" value="delete">
      
      <button> logout</button>
  </form>


    <a href="/resource/new">Add new resource</a>
    <section class="all_resources">

        <% all_resources.each do |resource| %>
            <article class="resource_item">
                <h2><%= resource['name'] %></h2>
                <h3><%="#{resource['description']}"%></h3>
                <h3><%="#{resource['url']}"%></h3>
                <a href="/resource/<%=resource['id']%>/edit">Edit</a>

            <form onsubmit="return confirm('Are you sure you want to delete this resource?');" action="/resource/<%= resource['id'] %>" method="POST">
            <input type="hidden" name="_method" value="delete">

            <button>Delete</button>
            </form>

            </article>
        <% end %>
    </section>




    <% else %>
    <a href="/sign_up">Sign Up</a>
    <a href="/login">Login</a>

    
<% end %>