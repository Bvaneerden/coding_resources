<h1>Edit Resource</h1>

<form action="/resource/<%= resource['id'] %>" method="POST">
    <input type="hidden" name="_method" value="put">
   
    <label for="">Name: </label>
    <input type="text" name = "name" value ="<%= resource['name'] %>">

    <label for="">Description: </label>
    <input type="text" name = "description" value ="<%= resource['description'] %>">

    <label for="">URL: </label>
    <input type="text" name = "url" value ="<%= resource['url'] %>">

    <label for="">Languages:</label>
    <input type="checkbox" name="html" value='true'>
    <label for="HTML">HTML</label>
    <img src="https://png.pngitem.com/pimgs/s/552-5526152_ornate-html5-logo-html-5-hd-png-download.png" alt="HTML5 Logo">
    
    <input type="checkbox" name="css" value='true'>
    <label for="CSS">CSS</label>
    <img src="https://png.pngitem.com/pimgs/s/198-1985002_css3-logo-hd-png-download.png" alt="CSS Logo">

    <input type="checkbox" name="javascript" value='true'>
    <label for="Javascript">JavaScript</label>
    <img src="https://png.pngitem.com/pimgs/s/116-1167737_logo-javascript-pattern-copyright-framework-free-download-javascript.png" alt="JS Logo">

    <input type="checkbox" name="ruby" value='true'>
    <label for="Ruby">Ruby</label>
    <img src="https://png.pngitem.com/pimgs/s/12-120179_best-free-ruby-png-ruby-programming-language-logo.png" alt="Ruby Logo">

    <input type="checkbox" name="ruby_on_rails" value='true'>
    <label for="ruby_on_rails">Ruby on Rails</label>
    <img src="https://png.pngitem.com/pimgs/s/360-3600482_ruby-on-rails-logo-ruby-on-rails-logo.png" alt="Ruby on RailsLogo">

    <input type="checkbox" name="postgresql" value='true'>
    <label for="postgresql">Postgresql</label>
    <img src="https://png.pngitem.com/pimgs/s/151-1512647_postgresql-elephant-logo-postgresql-logo-vector-hd-png.png" alt="Postgresql Logo">

    <input type="checkbox" name="python" value='true'>
    <label for="python">Python</label>
    <img src="https://png.pngitem.com/pimgs/s/159-1595932_python-logo-png-transparent-images-logo-transparent-background.png" alt="Python Logo">

    <button>Update resource</button>
</form>
